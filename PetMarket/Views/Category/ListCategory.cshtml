@model IEnumerable<PetMarket.Models.Category>
@{
	ViewData["Title"] = "Manage Categories";
	Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
	<div class="d-flex justify-content-between align-items-center mb-4">
		<h2 class="mb-0">
			<i class="bi bi-tags-fill text-success me-2"></i>Categories
		</h2>
		<a href="/admin/categories/create" class="btn btn-success">
			<i class="bi bi-plus-circle me-2"></i>Add New Category
		</a>
	</div>

	<div class="card shadow-sm border-0">
		<div class="card-body p-0">
			@if (Model != null && Model.Any())
			{
				<div class="accordion accordion-flush" id="categoryAccordion">
					@foreach (var category in Model.Where(c => c.ParentCategoryId == null).OrderBy(c => c.NameCategory))
					{
						var targetId = $"collapse-{category.IdCategory}";
						var subcategoriesExist = category.Subcategories != null && category.Subcategories.Any();

						<div class="accordion-item border-top">
							
							<h2 class="accordion-header d-flex align-items-center" id="heading-@category.IdCategory">

								
								<button class="accordion-button collapsed bg-light flex-grow-1 pe-0 me-3" type="button"
										data-bs-toggle="@(subcategoriesExist ? "collapse" : "false")"
										data-bs-target="#@targetId"
										aria-expanded="false"
										aria-controls="@targetId"
										@(subcategoriesExist ? "" : "disabled")>

									
									<div class="row w-100 align-items-center ps-2">
										<div class="col-md-1 fw-bold text-dark">
											@category.IdCategory
										</div>
										<div class="col-md-3"> 
											<span class="badge bg-success">
												<i class="bi bi-tag me-1"></i>@category.NameCategory
											</span>
										</div>
										<div class="col-md-8 text-muted text-truncate"> 
											@((category.DescriptionCategory?.Length > 50 ? category.DescriptionCategory.Substring(0, 50) + "..." : category.DescriptionCategory) ?? "No description")
										</div>
										
									</div>
								</button>

								
								<span class="d-flex align-items-center text-end pe-4 py-2 flex-shrink-0">
									<a href="/admin/categories/create?parentId=@category.IdCategory" class="btn btn-sm btn-outline-success me-2">
										<i class="bi bi-plus-circle me-1"></i>Add Subcategory
									</a>
									<a href="/admin/categories/edit/@category.IdCategory" class="btn btn-sm btn-outline-warning me-2">
										<i class="bi bi-pencil-square me-1"></i>Edit
									</a>
									<a href="/admin/categories/delete/@category.IdCategory" class="btn btn-sm btn-outline-danger">
										<i class="bi bi-trash me-1"></i>Delete
									</a>
								</span>
							</h2>

							@if (subcategoriesExist)
							{
								<div id="@targetId" class="accordion-collapse collapse" aria-labelledby="heading-@category.IdCategory" data-bs-parent="#categoryAccordion">
									<div class="accordion-body p-0">
										<div class="table-responsive">
											<table class="table table-striped table-sm mb-0">
												<thead class="bg-light-subtle">
													<tr>
														<th class="ps-4">ID</th>
														<th>Subcategory Name</th>
														<th class="col-6">Description</th>
														
														<th class="text-end pe-4"><i class="bi bi-gear-fill me-2"></i>Actions</th>
													</tr>
												</thead>
												<tbody>
													@foreach (var sub in category.Subcategories.OrderBy(s => s.NameCategory))
													{
														
														<tr>
															<td class="ps-4">@sub.IdCategory</td>
															<td>
																<span class="badge bg-secondary">
																	@sub.NameCategory
																</span>
															</td>
															<td class="col-6"> 
																<span class="text-muted">
																	@(sub.DescriptionCategory?.Length > 50 ? sub.DescriptionCategory.Substring(0, 50) + "..." : sub.DescriptionCategory)
																</span>
															</td>
															
															<td class="text-end pe-4">
																
																<a href="/admin/categories/create?parentId=@sub.IdCategory" class="btn btn-sm btn-outline-success me-2">
																	<i class="bi bi-plus-circle me-1"></i>Add Subcategory
																</a>
																<a href="/admin/categories/edit/@sub.IdCategory" class="btn btn-sm btn-outline-warning me-2">
																	<i class="bi bi-pencil-square me-1"></i>Edit
																</a>
																<a href="/admin/categories/delete/@sub.IdCategory" class="btn btn-sm btn-outline-danger">
																	<i class="bi bi-trash me-1"></i>Delete
																</a>
															</td>
														</tr>

														
														@if (sub.Subcategories != null && sub.Subcategories.Any())
														{
															@foreach (var subsub in sub.Subcategories.OrderBy(s => s.NameCategory))
															{
																<tr class="table-light">
																	
																	<td class="ps-5">@subsub.IdCategory</td>
																	<td>
																		<span class="badge bg-dark ms-3">
																			@subsub.NameCategory
																		</span>
																	</td>
																	<td class="col-6"> 
																		<span class="text-muted fst-italic">
																			@(subsub.DescriptionCategory?.Length > 50 ? subsub.DescriptionCategory.Substring(0, 50) + "..." : subsub.DescriptionCategory)
																		</span>
																	</td>
																	
																	<td class="text-end pe-4">
																		
																		<a href="/admin/categories/edit/@subsub.IdCategory" class="btn btn-sm btn-outline-warning me-2">
																			<i class="bi bi-pencil-square me-1"></i>Edit
																		</a>
																		<a href="/admin/categories/delete/@subsub.IdCategory" class="btn btn-sm btn-outline-danger">
																			<i class="bi bi-trash me-1"></i>Delete
																		</a>
																	</td>
																</tr>
															}
														}
													}
												</tbody>
											</table>
										</div>
									</div>
								</div>
							}
						</div>
					}
				</div>
			}
			else
			{
				<div class="text-center py-5">
					<i class="bi bi-inbox display-1 text-muted"></i>
					<p class="text-muted mt-3">No categories found. Add your first category!</p>
				</div>
			}
		</div>
	</div>
</div>