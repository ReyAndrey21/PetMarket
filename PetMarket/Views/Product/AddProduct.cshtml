@model PetMarket.Models.Product
@{
    ViewData["Title"] = "Add Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-plus-circle-fill me-2"></i>Add New Product
                    </h4>
                </div>

                <div class="card-body p-4">
                    <form action="/admin/products/create" method="post" enctype="multipart/form-data">

                        <div class="mb-3">
                            <label asp-for="NameProduct" class="form-label fw-bold">
                                <i class="bi bi-tag-fill me-2 text-primary"></i>Product Name
                            </label>
                            <input asp-for="NameProduct" class="form-control" placeholder="Enter product name" required />
                            <span asp-validation-for="NameProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BrandProduct" class="form-label fw-bold">
                                <i class="bi bi-buildings-fill me-2 text-primary"></i>Brand
                            </label>
                            <input asp-for="BrandProduct" class="form-control" placeholder="Enter product brand" required />
                            <span asp-validation-for="BrandProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DescriptionProduct" class="form-label fw-bold">
                                <i class="bi bi-file-text me-2 text-primary"></i>Description
                            </label>
                            <textarea asp-for="DescriptionProduct" class="form-control" rows="3" placeholder="Enter product description" required></textarea>
                            <span asp-validation-for="DescriptionProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PriceProduct" class="form-label fw-bold">
                                <i class="bi bi-cash-coin me-2 text-primary"></i>Price
                            </label>
                            <input asp-for="PriceProduct" type="number" step="0.1" min="0" class="form-control" placeholder="Enter product price" required />
                            <span asp-validation-for="PriceProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StockProduct" class="form-label fw-bold">
                                <i class="bi bi-box-seam me-2 text-primary"></i>Stock Quantity
                            </label>
                            <input asp-for="StockProduct" type="number" min="0" class="form-control" placeholder="Enter available stock" required />
                            <span asp-validation-for="StockProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="IdCategory" class="form-label fw-bold">
                                <i class="bi bi-tags-fill me-2 text-primary"></i>Category
                            </label>
                            <select asp-for="IdCategory" asp-items="@(new SelectList(ViewBag.Categories, "IdCategory", "NameCategory"))" class="form-select" required>
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="IdCategory" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>Select the category this product belongs to
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageProduct" class="form-label fw-bold">
                                <i class="bi bi-image-fill me-2 text-primary"></i>Product Image
                            </label>
                            <input asp-for="ImageProduct" type="file" class="form-control" accept="image/*" required />
                            <span asp-validation-for="ImageProduct" class="text-danger"></span>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>Upload a clear image of the product
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a href="/admin/products" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Save Product
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}