@model PetMarket.Models.Product
@{
    ViewData["Title"] = "Delete Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Product
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning border-warning">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        <strong>Are you sure you want to delete this product?</strong>
                        <p class="mb-0 mt-2">This action cannot be undone. **The product image will also be permanently deleted.**</p>
                    </div>

                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">
                                    <i class="bi bi-hash me-2 text-muted"></i>ID:
                                </dt>
                                <dd class="col-sm-8 fw-bold">#@Model.IdProduct</dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-tag-fill me-2 text-muted"></i>Name:
                                </dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-success">
                                        <i class="bi bi-tag me-1"></i>@Model.NameProduct
                                    </span>
                                </dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-buildings-fill me-2 text-muted"></i>Brand:
                                </dt>
                                <dd class="col-sm-8 fw-bold">@Model.BrandProduct</dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-file-text me-2 text-muted"></i>Description:
                                </dt>
                                <dd class="col-sm-8 text-muted">@Model.DescriptionProduct</dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-cash-stack me-2 text-muted"></i>Price:
                                </dt>
                                <dd class="col-sm-8 fw-bold">@Model.PriceProduct.ToString("C")</dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-box-seam me-2 text-muted"></i>Stock:
                                </dt>
                                <dd class="col-sm-8 fw-bold">@Model.StockProduct</dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-diagram-3 me-2 text-muted"></i>Category:
                                </dt>
                                <dd class="col-sm-8">
                                    @if (Model.Category != null)
                                    {
                                        <span class="badge bg-info text-dark">
                                            <i class="bi bi-diagram-3 me-1"></i>@Model.Category.NameCategory
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-image me-2 text-muted"></i>Image:
                                </dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.ImageProductUrl))
                                    {
                                        <img src="@Model.ImageProductUrl" alt="Product Image" class="img-thumbnail" style="max-height: 150px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">No image</span>
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <form asp-action="DeleteConfirmedProduct" asp-controller="Product" asp-route-id="@Model.IdProduct" method="post">
                        <input type="hidden" asp-for="IdProduct" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a asp-action="ListProduct" asp-controller="Product" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Delete Product
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>