@model PetMarket.Models.Product

@{
    ViewData["Title"] = "Edit Product";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-pencil-square me-2"></i>Edit Product
                    </h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditProduct" asp-controller="Product" asp-route-id="@Model.IdProduct" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="IdProduct" />

                        <div class="mb-3">
                            <label asp-for="NameProduct" class="form-label fw-bold">
                                <i class="bi bi-tag-fill me-2 text-primary"></i>Product Name
                            </label>
                            <input asp-for="NameProduct" class="form-control" placeholder="Enter product name" required />
                            <span asp-validation-for="NameProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="BrandProduct" class="form-label fw-bold">
                                <i class="bi bi-buildings-fill me-2 text-primary"></i>Brand
                            </label>
                            <input asp-for="BrandProduct" class="form-control" placeholder="Enter brand name" required />
                            <span asp-validation-for="BrandProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="DescriptionProduct" class="form-label fw-bold">
                                <i class="bi bi-file-text me-2 text-primary"></i>Description
                            </label>
                            <textarea asp-for="DescriptionProduct" class="form-control" rows="3" placeholder="Enter product description" required></textarea>
                            <span asp-validation-for="DescriptionProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="PriceProduct" class="form-label fw-bold">
                                <i class="bi bi-cash-stack me-2 text-primary"></i>Price
                            </label>
                            <input asp-for="PriceProduct" type="number" step="0.01" class="form-control" placeholder="Enter price" required />
                            <span asp-validation-for="PriceProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="StockProduct" class="form-label fw-bold">
                                <i class="bi bi-box-seam me-2 text-primary"></i>Stock Quantity
                            </label>
                            <input asp-for="StockProduct" type="number" min="0" class="form-control" placeholder="Enter stock quantity" required />
                            <span asp-validation-for="StockProduct" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="IdCategory" class="form-label fw-bold">
                                <i class="bi bi-diagram-3 me-2 text-primary"></i>Category
                            </label>
                            <select asp-for="IdCategory" asp-items="@(new SelectList(ViewBag.Categories, "IdCategory", "NameCategory", Model.IdCategory))" class="form-select" required>
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="IdCategory" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="bi bi-image me-2 text-primary"></i>Product Image (Leave blank to keep current)
                            </label>
                            <input asp-for="ImageProduct" type="file" class="form-control" accept="image/*" />

                            @if (!string.IsNullOrEmpty(Model.ImageProductUrl))
                            {
                                <div class="mt-3 text-center">
                                    <img src="@Model.ImageProductUrl" alt="Current" class="img-thumbnail" style="max-height: 200px;" />
                                    <div class="form-text mt-1">Current image preview</div>
                                </div>
                            }
                        </div>

                        <div class="mb-3">
                            <label asp-for="DescriptionPdf" class="form-label fw-bold">
                                <i class="bi bi-file-earmark-pdf-fill me-2 text-danger"></i>Product PDF Document (Leave blank to keep current)
                            </label>

                            @if (!string.IsNullOrEmpty(Model.DescriptionPdfUrl))
                            {
                                <div class="alert alert-secondary d-flex align-items-center mb-2 py-2">
                                    <i class="bi bi-file-check-fill me-2 text-success"></i>
                                    <span class="small me-auto">Current document is attached.</span>
                                    <a href="@Model.DescriptionPdfUrl" target="_blank" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye-fill me-1"></i>View PDF
                                    </a>
                                </div>
                            }

                            <input asp-for="DescriptionPdf" type="file" class="form-control" accept="application/pdf" />
                            <span asp-validation-for="DescriptionPdf" class="text-danger"></span>
                            <div class="form-text">Upload a new PDF to replace the existing one.</div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="ListProduct" asp-controller="Product" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle me-2"></i>Update Product
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}