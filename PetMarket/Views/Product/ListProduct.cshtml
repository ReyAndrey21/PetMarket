@model IEnumerable<PetMarket.Models.Product>
@{
    ViewData["Title"] = "Manage Products";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-box-seam-fill text-primary me-2"></i>Products
        </h2>
        <a href="/admin/products/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Add New Product
        </a>
    </div>

    
    <form asp-controller="Product" asp-action="ListProduct" method="get" class="mb-4">
        <div class="input-group">
            <input type="text"
                   name="searchTerm"
                   value="@ViewData["CurrentFilter"]"
                   class="form-control"
                   placeholder="Search by product name" />
            <button class="btn btn-secondary" type="submit">
                <i class="bi bi-search me-1"></i> Search
            </button>
            @if (!string.IsNullOrEmpty((string?)ViewData["CurrentFilter"]))
            {
                <a asp-controller="Product" asp-action="ListProduct" class="btn btn-outline-secondary">
                    <i class="bi bi-x-circle me-1"></i> Clear Filter
                </a>
            }
        </div>
    </form>
   

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-primary">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th><i class="bi bi-box me-2"></i>Name</th>
                                <th><i class="bi bi-buildings-fill me-2"></i>Brand</th>
                                <th><i class="bi bi-file-text me-2"></i>Description</th>
                                <th><i class="bi bi-cash-coin me-2"></i>Price</th>
                                <th><i class="bi bi-stack me-2"></i>Stock</th>
                                <th><i class="bi bi-card-image me-2"></i>Image</th>
                                <th><i class="bi bi-tags me-2"></i>Category</th>
                                <th class="text-end pe-4"><i class="bi bi-gear-fill me-2"></i>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var product in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@product.IdProduct</td>
                                    <td>
                                        <span class="badge bg-primary">
                                            <i class="bi bi-box2 me-1"></i>@product.NameProduct
                                        </span>
                                    </td>
                                    <td>
                                        <span class="text-muted">@product.BrandProduct</span>
                                    </td>
                                    <td>
                                        <span class="text-muted">
                                            @(product.DescriptionProduct?.Length > 50 ? product.DescriptionProduct.Substring(0, 50) + "..." : product.DescriptionProduct)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-semibold text-success">@product.PriceProduct.ToString("C")</span>
                                    </td>
                                    <td>
                                        @if (product.StockProduct > 0)
                                        {
                                            <span class="badge bg-success">@product.StockProduct</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Out of stock</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(product.ImageProductUrl))
                                        {
                                            <img src="@product.ImageProductUrl" alt="@product.NameProduct" width="60" height="60" class="rounded shadow-sm border" />

                                        }
                                        else
                                        {
                                            <i class="bi bi-image text-muted"></i>
                                        }
                                    </td>
                                    <td>
                                        @if (product.Category != null)
                                        {
                                            <span class="badge bg-info text-dark">
                                                <i class="bi bi-tag-fill me-1"></i>@product.Category.NameCategory
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/admin/products/edit/@product.IdProduct" class="btn btn-sm btn-outline-warning me-2">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>
                                        <a href="/admin/products/delete/@product.IdProduct" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-box-seam display-1 text-muted"></i>
                    @if (!string.IsNullOrEmpty((string?)ViewData["CurrentFilter"]))
                    {
                        <p class="text-muted mt-3">No products found matching the search criteria **"@ViewData["CurrentFilter"]"**.</p>
                    }
                    else
                    {
                        <p class="text-muted mt-3">No products found. Add your first product!</p>
                    }
                </div>
            }
        </div>
    </div>
</div>