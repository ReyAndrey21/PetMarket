@model IEnumerable<PetMarket.Models.User>

@{
    ViewData["Title"] = "Manage Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="bi bi-people-fill text-primary me-2"></i>Registered Users
        </h2>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th><i class="bi bi-person-fill me-1"></i>First Name</th>
                                <th><i class="bi bi-person-fill me-1"></i>Last Name</th>
                                <th><i class="bi bi-person-badge me-1"></i>Username</th>
                                <th><i class="bi bi-envelope-at me-1"></i>Email</th>
                                <th><i class="bi bi-telephone-fill me-1"></i>Phone</th>
                                <th><i class="bi bi-calendar3 me-1"></i>Created At</th>
                            </tr>
                        </thead>
                        <tbody class="align-middle">
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted" style="font-size:0.9rem">@user.Id</td>
                                    <td>
                                        <span class="fw-semibold">@user.FirstName</span>
                                    </td>
                                    <td>
                                        <span class="fw-semibold">@user.LastName</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@user.UserName</span>
                                    </td>
                                    <td>
                                        @user.Email
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(user.PhoneNumber))
                                        {
                                            <span>@user.PhoneNumber</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="text-muted">@user.CreatedAt.ToString("dd MMM yyyy")</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-people display-1 text-muted"></i>
                    <p class="text-muted mt-3">No users found.</p>
                </div>
            }
        </div>
    </div>
</div>
