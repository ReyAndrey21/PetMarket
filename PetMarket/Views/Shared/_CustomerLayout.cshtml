<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PetMarket</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/navbar.css" asp-append-version="true" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />


</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-custom navbar-toggleable-sm border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="CustomerDashboard" asp-action="HomePage">PetMarket</a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav">
                        <li class="nav-item px-3">
                            <a class="nav-link" href="/home">Home</a>
                        </li>
                        <li class="nav-item px-3">
                            <a class="nav-link" href="/products">Products</a>
                        </li>
                        <li class="nav-item px-3">
                            <a class="nav-link" href="/categories">Categories</a>
                        </li>
                        <li class="nav-item px-3">
                            <a class="nav-link" asp-controller="ShoppingCart" asp-action="Index">
                                <i class="bi bi-cart3 me-1"></i>
                            </a>
                        </li> 
                        <li class="nav-item px-3">
                            <a class="nav-link" asp-controller="Favorites" asp-action="Index">Wishlist</a>
                        </li>
                        <li class="nav-item px-3">
                            @if (User.Identity.IsAuthenticated)
                             {
                                <a class="nav-link" href="/account/profile">Account</a>
							}
                            else
                            {
                                <a class="nav-link" href="/account/login">Account</a>
							}
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - PetMarket
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/wishlist.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
