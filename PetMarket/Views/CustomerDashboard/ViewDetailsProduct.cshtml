@model PetMarket.Models.Product

@{
    ViewData["Title"] = "Product Details";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="container my-5">
    <div class="row justify-content-center align-items-start g-5">
        <div class="col-md-5 text-center">
            @if (!string.IsNullOrEmpty(Model.ImageProductUrl))
            {
                <img src="@Model.ImageProductUrl"
                     alt="@Model.NameProduct"
                     class="img-fluid rounded shadow-sm"
                     style="max-height: 400px; object-fit: contain;" />
            }
            else
            {
                <div class="d-flex align-items-center justify-content-center bg-light rounded" style="height: 350px;">
                    <i class="bi bi-image fs-1 text-muted"></i>
                </div>
            }
        </div>

        <div class="col-md-6">
            <h2 class="fw-bold text-success mb-3">@Model.NameProduct</h2>

            @if (Model.Category != null)
            {
                <p class="text-muted mb-3">
                    <i class="bi bi-tag-fill me-1"></i>
                    <strong>@Model.Category.NameCategory</strong>
                </p>
            }

            <p class="text-secondary mb-4 fs-6">@Model.DescriptionProduct</p>

            <h3 class="fw-bold text-success mb-3">@Model.PriceProduct.ToString("C")</h3>

            <span class="badge @(Model.StockProduct > 0 ? "bg-success" : "bg-danger") mb-4">
                @(Model.StockProduct > 0 ? "In stock" : "Out of stock")
            </span>

           
            @if (!string.IsNullOrEmpty(Model.DescriptionPdfUrl))
            {
                <div class="mb-4">
                    <a href="@Model.DescriptionPdfUrl" target="_blank" class="btn btn-outline-secondary">
                        <i class="bi bi-file-earmark-pdf-fill me-2 text-danger"></i>Descarcă Specificații PDF
                    </a>
                </div>
            }
           

            <div class="mt-3">
                @if (Model.StockProduct > 0)
                {
                    <form asp-controller="ShoppingCart" asp-action="AddToCart" method="post" class="d-inline d-flex align-items-center gap-2">
                        <input type="hidden" name="productId" value="@Model.IdProduct" />
                        <div class="input-group" style="width: 140px;">
                            <button type="button" class="btn btn-outline-secondary" id="btn-decrement"><i class="bi bi-dash"></i></button>
                            <input type="number" name="quantity" id="quantity" class="form-control text-center" value="1" min="1" max="@Model.StockProduct">
                            <button type="button" class="btn btn-outline-secondary" id="btn-increment"><i class="bi bi-plus"></i></button>
                        </div>
                        <button type="submit" class="btn btn-success px-4 py-2">
                            <i class="bi bi-cart-plus me-2"></i>Add to Cart
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary px-4 py-2" disabled>
                        <i class="bi bi-cart-x me-2"></i>Out of Stock
                    </button>
                }
            </div>

            <div class="mt-4">
                <a asp-action="Products" class="text-decoration-none text-success fw-semibold">
                    <i class="bi bi-arrow-left-circle me-1"></i>Back to Products
                </a>
            </div>
        </div>
    </div>

   
    <div class="row mt-5 justify-content-center">
        <div class="col-md-11">
            <hr />
            <h3 class="mb-4">Reviews (@(Model.Review?.Count ?? 0))</h3>

            @if (Model.Review != null && Model.Review.Any())
            {
                @foreach (var review in Model.Review)
                {
                    <div class="card mb-3 shadow-sm border-0 bg-light">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="card-title fw-bold mb-0 text-dark">
                                    <i class="bi bi-person-circle me-2"></i>@review.User?.FirstName @review.User?.LastName
                                </h6>
                                <span class="text-warning fw-bold">
                                    @for (int i = 0; i < review.RatingReview; i++)
                                    {
                                        <i class="bi bi-star-fill"></i>
                                    }
                                    @review.RatingReview / 5
                                </span>
                            </div>
                            <p class="card-text text-secondary">@review.Comment</p>
                            <div class="text-muted small">
                                <i class="bi bi-calendar3 me-1"></i> @review.DateReview.ToString("MM/dd/yyyy")
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-light text-center border">
                    There are no reviews for this product yet. Be the first to leave one!
                </div>
            }

            @if (User.Identity.IsAuthenticated)
            {
                <div class="card mt-5 p-4 border-success shadow-sm" style="border-left: 5px solid #198754;">
                    <h5 class="fw-bold text-success mb-3"><i class="bi bi-chat-left-dots me-2"></i>Leave a review</h5>
                    <form asp-controller="Review" asp-action="Create" method="post">
                        <input type="hidden" name="IdProduct" value="@Model.IdProduct" />
                        <div class="row mb-3">
                            <div class="col-md-3">
                                <label class="form-label fw-semibold">Rating:</label>
                                <select name="RatingReview" class="form-select border-success">
                                    <option value="5">5 ★ (Excellent)</option>
                                    <option value="4">4 ★ (Good)</option>
                                    <option value="3">3 ★ (Average)</option>
                                    <option value="2">2 ★ (Poor)</option>
                                    <option value="1">1 ★ (Very Poor)</option>
                                </select>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Comment:</label>
                            <textarea name="Comment" class="form-control border-success" rows="3" required placeholder="Tell us what you think about @Model.NameProduct..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-success px-5">
                            Submit Review <i class="bi bi-send ms-2"></i>
                        </button>
                    </form>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const btnIncrement = document.getElementById("btn-increment");
        const btnDecrement = document.getElementById("btn-decrement");
        const quantityInput = document.getElementById("quantity");

        btnIncrement.addEventListener("click", () => {
            let current = parseInt(quantityInput.value);
            if(current < @Model.StockProduct){
                quantityInput.value = current + 1;
            }
        });

        btnDecrement.addEventListener("click", () => {
            let current = parseInt(quantityInput.value);
            if(current > 1){
                quantityInput.value = current - 1;
            }
        });
    </script>
}