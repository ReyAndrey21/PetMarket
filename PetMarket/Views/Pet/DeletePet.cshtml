@model PetMarket.Models.Pet
@{
    ViewData["Title"] = "Delete Pet";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Delete Pet
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div class="alert alert-warning border-warning">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        <strong>Are you sure you want to delete this pet?</strong>
                        <p class="mb-0 mt-2">This action cannot be undone. **The associated image will also be deleted.**</p>
                    </div>

                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">
                                    <i class="bi bi-hash me-2 text-muted"></i>ID:
                                </dt>
                                <dd class="col-sm-8 fw-bold">@Model.IdPet</dd>

                                <dt class="col-sm-4">
                                    <i class="bi bi-tag-fill me-2 text-muted"></i>Type:
                                </dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-info text-dark">
                                        <i class="bi bi-paw-fill me-1"></i>@Model.TypePet
                                    </span>
                                </dd>

                               
                                <dt class="col-sm-4">
                                    <i class="bi bi-image-fill me-2 text-muted"></i>Image:
                                </dt>
                                <dd class="col-sm-8">
                                    @if (!string.IsNullOrEmpty(Model.ImagePetUrl))
                                    {
                                        <img src="@Model.ImagePetUrl" alt="@Model.TypePet" class="img-thumbnail" style="max-width: 150px; max-height: 150px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">No image uploaded.</span>
                                    }
                                </dd>
                               

                            </dl>
                        </div>
                    </div>

                    <form action="/admin/pets/delete/@Model.IdPet" method="post">
                        <input type="hidden" asp-for="IdPet" />
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/admin/pets" class="btn btn-outline-secondary">
                                <i class="bi bi-x-circle me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-2"></i>Delete Pet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>