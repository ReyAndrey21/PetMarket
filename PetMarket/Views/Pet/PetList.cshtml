@model IEnumerable<PetMarket.Models.Pet>
@{
    ViewData["Title"] = "Manage Pets";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">
            <i class="fas fa-paw"></i>Pets
        </h2>
        <a href="/admin/pets/create" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Add New Pet
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Image</th>
                                <th>Type pet</th>
                                <th class="text-end pe-4"><i class="bi bi-gear-fill me-2"></i>Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var pet in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold">@pet.IdPet</td>
                                    <td style="width: 80px;">
                                        @if (!string.IsNullOrEmpty(pet.ImagePetUrl))
                                        {
                                            <img src="@pet.ImagePetUrl" alt="@pet.TypePet" style="width: 60px; height: 60px; object-fit: cover; border-radius: 8px;" class="img-thumbnail" />
                                        }
                                        else
                                        {
                                            <i class="bi bi-image-alt text-muted" style="font-size: 24px;"></i>
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            <i class="bi bi-paw-fill me-1"></i>@pet.TypePet
                                        </span>
                                    </td>
                                    <td class="text-end pe-4">
                                        <a href="/admin/pets/edit/@pet.IdPet" class="btn btn-sm btn-outline-warning me-2">
                                            <i class="bi bi-pencil-square me-1"></i>Edit
                                        </a>
                                        <a href="/admin/pets/delete/@pet.IdPet" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash me-1"></i>Delete
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox display-1 text-muted"></i>
                    <p class="text-muted mt-3">No pets found. Add your first pet!</p>
                </div>
            }
        </div>
    </div>
</div>