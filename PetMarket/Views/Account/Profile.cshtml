@model PetMarket.Models.User

@{
    ViewData["Title"] = "User Profile";
    Layout = "~/Views/Shared/_CustomerLayout.cshtml";
}

<div class="container my-5">

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <div class="mb-3">
                        @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                        {
                            <img src="@Model.ProfilePictureUrl"
                                 class="rounded-circle border border-3 border-white shadow-sm"
                                 alt="Profile picture"
                                 style="width: 80px; height: 80px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-white text-success d-inline-flex align-items-center justify-content-center shadow-sm"
                                 style="width: 80px; height: 80px; font-size: 2rem; font-weight: bold;">
                                @(Model.FirstName?.Substring(0, 1) ?? "U")@(Model.LastName?.Substring(0, 1) ?? "")
                            </div>
                        }
                    </div>
                    <h4 class="mb-0">@Model.FirstName @Model.LastName</h4>
                    <small class="opacity-75">@Model.UserName</small>
                </div>
                <div class="card-body p-4">
                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-envelope-fill text-primary me-2"></i>
                            <strong>Email:</strong>
                        </div>
                        <div class="ms-4 text-muted">@Model.Email</div>
                    </div>

                    <div class="mb-3 pb-3 border-bottom">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-telephone-fill text-primary me-2"></i>
                            <strong>Phone:</strong>
                        </div>
                        <div class="ms-4 text-muted">@(Model.PhoneNumber ?? "Not provided")</div>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex align-items-center mb-2">
                            <i class="bi bi-calendar-check-fill text-primary me-2"></i>
                            <strong>Member Since:</strong>
                        </div>
                        <div class="ms-4 text-muted">@Model.CreatedAt.ToString("dd MMMM yyyy")</div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 p-4 d-flex justify-content-center gap-2">
                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-box-arrow-right me-2"></i>Logout
                        </button>
                    </form>

                    <a asp-action="EditProfile" asp-controller="Account" class="btn btn-outline-primary">
                        <i class="bi bi-pencil-square me-2"></i>Edit Profile
                    </a>
                </div>
            </div>
        </div>
    </div>


    <div class="row justify-content-center mt-4">
        <div class="col-md-11 col-lg-10">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-dark text-white p-3">
                    <h5 class="mb-0"><i class="bi bi-clock-history me-2"></i>Order History</h5>
                </div>
                <div class="card-body">
                    @if (Model.Order == null || !Model.Order.Any())
                    {
                        <div class="text-center py-4">
                            <p class="text-muted">You haven't placed any orders yet.</p>
                            <a href="@Url.Action("Products", "CustomerDashboard")" class="btn btn-sm btn-success">Go Shopping</a>
                        </div>
                    }
                    else
                    {
                        <div class="table-responsive">
                            <table class="table table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Date</th>
                                        <th>Total</th>
                                        <th>Products</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var order in Model.Order.OrderByDescending(o => o.OrderDate))
                                    {
                                        <tr>
                                            <td><strong>#@order.IdOrder</strong></td>
                                            <td>@order.OrderDate.ToString("MM/dd/yyyy")</td>
                                            <td class="fw-bold">@order.TotalAmount RON</td>
                                            <td>
                                                <ul class="list-unstyled mb-0 small">
                                                    @if (order.OrderDetails != null)
                                                    {
                                                        @foreach (var detail in order.OrderDetails)
                                                        {
                                                            <li>@detail.Product?.NameProduct</li>
                                                        }
                                                    }
                                                </ul>
                                            </td>
                                            <td>
                                                <span class="badge bg-info text-dark">Processed</span>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />